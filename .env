# =============================================================================
# EGIDE — Dev environment (local only — ne jamais committer en prod)
# =============================================================================

# Application
APP_ENV=dev

# PostgreSQL
POSTGRES_DB=egide
POSTGRES_USER=egide
POSTGRES_PASSWORD=egide_dev_password_2026

# AES-256 field encryption
# Clé générée pour le dev local — à remplacer en prod
EGIDE_FIELD_ENCRYPTION_KEY_B64=dGhpcyBpcyBhIDMyIGJ5dGUgZGV2IGtleSBmb3IgZWdpZGU=

# Keycloak
KC_ADMIN_USER=admin
KC_ADMIN_PASSWORD=egide_kc_admin_2026
KEYCLOAK_ISSUER=http://localhost:8080/realms/egide
KEYCLOAK_JWKS_URL=http://keycloak:8080/realms/egide/protocol/openid-connect/certs
KEYCLOAK_AUDIENCE=egide-api
KEYCLOAK_VERIFY_AUDIENCE=true
KEYCLOAK_RSSI_ROLE=rssi

# Auth dev bypass — désactive la validation JWT en local
EGIDE_AUTH_DEV_BYPASS=true

# CORS
CORS_ORIGINS=http://localhost:3000

# Alembic
SQLALCHEMY_AUTO_CREATE_TABLES=false

# Mistral AI (mock utilisé en dev — pas besoin de vraie clé)
MISTRAL_API_KEY=dev_mock_key
MISTRAL_API_BASE_URL=https://api.mistral.ai/v1
MISTRAL_MODEL=mistral-small-latest
