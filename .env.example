# =============================================================================
# EGIDE — Environment variables template
# cp .env.example .env  then fill in every value marked with <CHANGE_ME>
# NEVER commit .env to version control
# =============================================================================

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
APP_ENV=dev
# APP_ENV=prod   # set to prod on staging/production — disables all dev bypasses

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
POSTGRES_DB=egide
POSTGRES_USER=egide
POSTGRES_PASSWORD=<CHANGE_ME>          # min 24 chars, random

# Constructed automatically by docker-compose — only override if external DB
# DATABASE_URL=postgresql+psycopg://egide:<password>@egide-db:5432/egide

# ---------------------------------------------------------------------------
# AES-256 field encryption (OSINT PII + campaign scenarios at rest)
# Generate a fresh key:
#   python3 -c "import secrets,base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
# ---------------------------------------------------------------------------
EGIDE_FIELD_ENCRYPTION_KEY_B64=<CHANGE_ME>   # base64-encoded 32-byte key

# ---------------------------------------------------------------------------
# Keycloak (sovereign Identity Provider)
# ---------------------------------------------------------------------------
KC_ADMIN_USER=admin
KC_ADMIN_PASSWORD=<CHANGE_ME>          # min 24 chars

KEYCLOAK_ISSUER=http://localhost:8080/realms/egide
KEYCLOAK_JWKS_URL=http://localhost:8080/realms/egide/protocol/openid-connect/certs
KEYCLOAK_AUDIENCE=egide-api
KEYCLOAK_VERIFY_AUDIENCE=true
KEYCLOAK_RSSI_ROLE=rssi

# ---------------------------------------------------------------------------
# Auth dev bypass — DEV/TEST ONLY
# Set to true to skip JWT validation locally (auto-disabled when APP_ENV=prod)
# ---------------------------------------------------------------------------
EGIDE_AUTH_DEV_BYPASS=true

# ---------------------------------------------------------------------------
# CORS (Next.js frontend)
# ---------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000

# ---------------------------------------------------------------------------
# Alembic (used inside container by CMD)
# ---------------------------------------------------------------------------
SQLALCHEMY_AUTO_CREATE_TABLES=false

# ---------------------------------------------------------------------------
# Mistral AI (social engineering engine — sovereign endpoint)
# ---------------------------------------------------------------------------
MISTRAL_API_KEY=<CHANGE_ME>
MISTRAL_API_BASE_URL=https://api.mistral.ai/v1   # or self-hosted vLLM endpoint
MISTRAL_MODEL=mistral-small-latest
